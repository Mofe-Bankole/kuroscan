# Telegram
BOT_TOKEN=

# Kora (sponsored tx / fee payer)
KORA_RPC_URL=
KORA_DEVNET_API=
KORA_SPONSOR_PUBLIC_KEY=
KORA_PRIVATE_KEY=

# Solana RPC (devnet for this bot)
SOLANA_DEVNET_RPC=
HELIUS_DEVNET_RPC=

# Optional mainnet RPC (reserved for future / production)
SOLANA_MAINNET_RPC=

# Supabase (stores sponsored account pubkeys + encrypted-at-rest handling recommended in prod)
NODE_PUBLIC_SUPABASE_URL=
NODE_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# HTTP
PORT=4070

# Comma-separated Telegram user IDs for auto-reclaim admin DMs
ADMIN_IDS=

# Set to "true" to start the periodic auto-reclaim worker (see src/cron/autoReclaim.ts)
ENABLE_AUTO_RECLAIM=
